# Plant Monitoring System - Local Development Environment
# ------------------------------------------------------------------------------
# Copy this file to .env and adjust values for your deployment.

# API Security
API_AUTH_TOKEN=pms-local-dev-token-change-in-production
# Comma-separated list of browser origins allowed to call the API (CORS).
# Do NOT use "*". Set this to the hostname(s) the dashboard is served from.
CORS_ALLOW_ORIGINS=https://plant-hub.local,https://10.55.152.203,http://localhost:8080

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# MQTT
MQTT_HOST=localhost
MQTT_PORT=8883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CA_CERT=

# InfluxDB
# NOTE: USERNAME + PASSWORD + TOKEN are REQUIRED for docker-compose first-run setup
# (DOCKER_INFLUXDB_INIT_MODE=setup). InfluxDB 2.x aborts initialization if the
# username is empty or the password is shorter than 8 characters, and the API
# container reuses INFLUXDB_TOKEN to authenticate writes. Leaving these blank is
# why the database never finishes preparing.
INFLUXDB_URL=http://localhost:8086
INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=change-me-in-production
INFLUXDB_TOKEN=pms-local-dev-influx-token-change-me
INFLUXDB_ORG=plantmonitor
INFLUXDB_BUCKET=telemetry
INFLUXDB_RETENTION=30d

# Chat provider — the only part of the system that requires internet access.
# CHAT_PROVIDER: "gemini" (free tier, good for testing) | "anthropic" (production)
CHAT_PROVIDER=gemini

# Gemini — get a free API key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# Anthropic Claude — paid (~$0.25/M tokens with Haiku); leave blank if using Gemini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Logging
LOG_LEVEL=INFO
