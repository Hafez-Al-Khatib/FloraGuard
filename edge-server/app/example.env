# PRODUCTION environment template.
# Copy this file to edge-server/.env and replace every secret below with a
# strong, unique value before running `docker compose up`.
#
#   cd edge-server && cp app/example.env .env && nano .env
#
# .env is gitignored — never commit real secrets.

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=ChangeMeRedisStrongPassword123!
REDIS_MAX_MEMORY=256mb

# ── MQTT (Mosquitto) ──────────────────────────────────────────────────────────
MQTT_USERNAME=pms-gateway
MQTT_PASSWORD=ChangeMeMqttStrongPassword123!

# ── InfluxDB ──────────────────────────────────────────────────────────────────
# USERNAME + PASSWORD (≥8 chars) + TOKEN are all REQUIRED for first-run setup.
INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=ChangeMeInfluxStrongPassword123!
INFLUXDB_ORG=plantmonitor
INFLUXDB_BUCKET=telemetry
INFLUXDB_RETENTION=30d
INFLUXDB_TOKEN=ChangeMeInfluxTokenForWritesAndQueries==

# ── API security ──────────────────────────────────────────────────────────────
# Shared bearer token presented by every device and the dashboard. Generate a
# fresh one:  openssl rand -hex 32
API_AUTH_TOKEN=ChangeMeApiTokenWithOpensslRandHex32
# Browser origins allowed to call the API (CORS). Comma-separated, no wildcard.
# Use the hostname(s) the dashboard is served from.
CORS_ALLOW_ORIGINS=https://plant-hub.local,https://10.55.152.203

# ── Chat provider ─────────────────────────────────────────────────────────────
# The ONLY part of the system that reaches the internet. Everything else
# (Redis, MQTT, InfluxDB, ONNX inference) runs fully offline.
# CHAT_PROVIDER: "gemini" (free tier) | "anthropic" (paid, production)
CHAT_PROVIDER=gemini
# Gemini — free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
# Anthropic Claude — paid (~$0.25/M tokens with Haiku); leave blank if using Gemini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
