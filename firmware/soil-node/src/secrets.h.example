// Plant Monitoring System — Soil Node credentials
// Copy this file to secrets.h, fill in your values, and flash.
// secrets.h is gitignored and must NEVER be committed.
#pragma once

// WiFi — primary: mobile hotspot (2.4 GHz band required, ESP32 has no 5 GHz)
#define WIFI_SSID "xrey's phone"
#define WIFI_PASS "rami1234"
// Fallback (previous home network) — swap back if the hotspot is unavailable:
// #define WIFI_SSID "your-greenhouse-wifi"
// #define WIFI_PASS "your-wifi-password"

// mDNS hostname of the Pi edge server (no ".local" suffix). The node resolves
// this over mDNS FIRST, so it keeps working when the hotspot hands the Pi a new
// IP; if the lookup fails (hotspot client isolation), MQTT_HOST below is the
// fallback. Must match the Pi's hostname (hostnamectl) — default: plant-hub.
#define EDGE_MDNS_NAME "plant-hub"

// MQTT broker — LAN IP of the Raspberry Pi edge server
// Primary: Pi static IP on the mobile hotspot (10.55.152.0/24)
#define MQTT_HOST "10.55.152.203"
// Fallback (previous home network):
// #define MQTT_HOST "192.168.10.100"
// Production broker: TLS-only listener on 8883 (there is no plain 1883).
#define MQTT_PORT 8883
#define MQTT_USER ""
#define MQTT_PASS ""

