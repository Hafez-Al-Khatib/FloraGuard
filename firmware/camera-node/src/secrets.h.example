// Plant Monitoring System — Camera Node (ESP32-CAM) credentials
// Copy this file to secrets.h, fill in your values, and flash via the TTL/FTDI
// adapter. secrets.h is gitignored and must NEVER be committed.
#pragma once

// WiFi (2.4 GHz only — ESP32 has no 5 GHz radio)
// Primary: mobile hotspot
#define WIFI_SSID "xrey's phone"
#define WIFI_PASS "rami1234"
// Fallback (previous home network):
// #define WIFI_SSID "your-greenhouse-wifi"
// #define WIFI_PASS "your-wifi-password"

// mDNS hostname of the Pi edge server (no ".local" suffix). The node resolves
// this over mDNS FIRST, so it keeps working when the hotspot hands the Pi a new
// IP; if the lookup fails (hotspot client isolation), API_BASE_URL below is
// the fallback. Must match the Pi's hostname (hostnamectl) — default: plant-hub.
#define EDGE_MDNS_NAME "plant-hub"

// FastAPI edge server. Plain HTTP on the LAN; production switches to https +
// the Jetson/Pi host (Phase 4).
// Primary: Pi static IP on the mobile hotspot (10.55.152.0/24)
#define API_BASE_URL "http://10.55.152.203:8000/api/v1"
// Fallback (previous home network — use the server's LAN IP, run `ipconfig`):
// #define API_BASE_URL "http://192.168.10.100:8000/api/v1"

// Bearer token. Two options:
//   * Quick start: use the shared admin token (API_AUTH_TOKEN from edge .env).
//   * Per-device (recommended): POST /node/{NODE_ID}/hello once with the admin
//     token to receive this node's own device_token, then paste it here. It can
//     be revoked individually if the device is lost.
#define API_TOKEN    "pms-local-dev-token-change-in-production"

// Unique identifier for this camera node (appears on the dashboard).
// The node only uploads frames to /node/{NODE_ID}/upload-frame; the edge
// auto-analyzes each frame, so no /analyze call is needed from firmware.
#define NODE_ID "camera-zone-a"
